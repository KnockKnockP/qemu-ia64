/*
 * IA-64 opcode ownership/evidence rows.
 *
 * The row order is deliberately identical to IA64Opcode.  Do not hand-sort:
 * scripts/ia64-gen-opcode-ledger.py --check enforces enum, decoder, and
 * typed-admission drift.
 *
 * SPDX-License-Identifier: GPL-2.0-or-later
 */


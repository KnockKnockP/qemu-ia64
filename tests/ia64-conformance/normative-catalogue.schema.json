{
  "$comment": "SPDX-License-Identifier: GPL-2.0-or-later",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vibtanium.ia64.normative-catalogue.schema",
  "title": "Vibtanium IA-64 normative catalogue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$comment",
    "schema",
    "schema_version",
    "catalogue_revision",
    "catalogue_policy",
    "profiles",
    "rows"
  ],
  "properties": {
    "$comment": {
      "const": "SPDX-License-Identifier: GPL-2.0-or-later"
    },
    "schema": {
      "const": "vibtanium.ia64.normative-catalogue"
    },
    "schema_version": {
      "const": 1
    },
    "catalogue_revision": {
      "type": "integer",
      "minimum": 1
    },
    "catalogue_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "derivation",
        "implementation_imports",
        "external_emulator_oracle"
      ],
      "properties": {
        "authority": {
          "type": "string",
          "minLength": 1
        },
        "derivation": {
          "const": "manually-authored-from-cited-specification"
        },
        "implementation_imports": {
          "const": false
        },
        "external_emulator_oracle": {
          "const": false
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+$"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/row"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "string_list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requirement_ids",
        "profiles",
        "interface_kind",
        "specification",
        "operation",
        "legal_inputs",
        "privilege",
        "state_read",
        "state_written",
        "predication",
        "nat_behavior",
        "possible_faults",
        "fault_priority",
        "committed_prefix",
        "restart_rule",
        "permitted_results",
        "required_evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{3}-[0-9]{3}(?:-[A-Z0-9]+)+$"
        },
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]{3}-[0-9]{3}$"
          }
        },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+$"
          }
        },
        "interface_kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]+$"
        },
        "specification": {
          "$ref": "#/$defs/specification"
        },
        "operation": {
          "$ref": "#/$defs/operation"
        },
        "legal_inputs": {
          "allOf": [
            {
              "$ref": "#/$defs/string_list"
            },
            {
              "minItems": 1
            }
          ]
        },
        "privilege": {
          "$ref": "#/$defs/privilege"
        },
        "state_read": {
          "$ref": "#/$defs/string_list"
        },
        "state_written": {
          "$ref": "#/$defs/string_list"
        },
        "predication": {
          "$ref": "#/$defs/predication"
        },
        "nat_behavior": {
          "$ref": "#/$defs/non_empty_string"
        },
        "possible_faults": {
          "$ref": "#/$defs/string_list"
        },
        "fault_priority": {
          "$ref": "#/$defs/string_list"
        },
        "committed_prefix": {
          "$ref": "#/$defs/non_empty_string"
        },
        "restart_rule": {
          "$ref": "#/$defs/non_empty_string"
        },
        "permitted_results": {
          "allOf": [
            {
              "$ref": "#/$defs/string_list"
            },
            {
              "minItems": 1
            }
          ]
        },
        "required_evidence": {
          "enum": [
            "E0",
            "E1",
            "E2",
            "E3",
            "E4"
          ]
        }
      }
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id",
        "title",
        "revision",
        "volume",
        "part",
        "section",
        "printed_pages",
        "manual_file",
        "anchor"
      ],
      "properties": {
        "document_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]+$"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "revision": {
          "$ref": "#/$defs/non_empty_string"
        },
        "volume": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "part": {
          "$ref": "#/$defs/non_empty_string"
        },
        "section": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+)*$"
        },
        "printed_pages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[1-4]:[0-9]+$"
          }
        },
        "manual_file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]+\\.pdf$"
        },
        "anchor": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "selector",
        "encoding"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9.-]+$"
        },
        "selector": {
          "$ref": "#/$defs/non_empty_string"
        },
        "encoding": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "privilege": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "levels",
        "rule"
      ],
      "properties": {
        "levels": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          }
        },
        "rule": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "predication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies",
        "rule"
      ],
      "properties": {
        "applies": {
          "type": "boolean"
        },
        "rule": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
